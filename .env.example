# === СКОПИРУЙТЕ В .env И ЗАПОЛНИТЕ ===

# Секретный ключ (мин. 64 символа)
# Генерация: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Админ-панель
ADMIN_EMAIL=admin@yourservice.ru
ADMIN_PASSWORD=

# База данных
POSTGRES_USER=seo
POSTGRES_PASSWORD=
POSTGRES_DB=seodb
DATABASE_URL=postgresql+asyncpg://seo:pass@postgres:5432/seodb

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Внешние API (опционально)
OPENSERP_URL=http://openserp:7000
YANDEX_OAUTH_TOKEN=
YANDEX_CLIENT_LOGIN=
RAPIDAPI_KEY=
XMLRIVER_USER_ID=
XMLRIVER_API_KEY=

# Окружение
ENVIRONMENT=production
